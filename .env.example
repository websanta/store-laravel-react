APP_NAME= # Enter your Application Name
APP_ENV= # Enter your Application ENV
APP_KEY= # Enter your Application Key
APP_DEBUG=true
APP_URL= # Enter your Application URL
APP_CURRENCY=USD

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_TIMEZONE=Europe/Moscow

APP_MAINTENANCE_DRIVER=file

# Docker user mapping (match your host user)
USER_ID= # Enter your user ID
GROUP_ID= # Enter your group ID

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT= # Enter your DB port
DB_DATABASE= # Enter your DB name
DB_USERNAME= # Enter your DB login
DB_PASSWORD= # Enter your DB password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST= # Enter your Redis hostname
REDIS_PASSWORD= # Enter your Redis password
REDIS_PORT= # Enter your Redis port

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME= # Enter your Email username
MAIL_PASSWORD= # Enter your Email password
MAIL_FROM_ADDRESS="email@domain.com" # Enter your site email
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_HOST= # Enter your Vite hostname
VITE_PORT= # Enter your Vite port
VITE_HMR_HOST= # Enter your Vite HMR hostname
VITE_HMR_PROTOCOL=wss

# Xdebug Configuration
ENABLE_XDEBUG=true
XDEBUG_MODE=debug,develop,coverage
XDEBUG_CONFIG=client_host=host.docker.internal

# Payments
PAYMENT_DRIVER=mock  # stripe or mock

STRIPE_KEY= # Enter pk_test_your_publishable_key
STRIPE_SECRET= # Enter sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET= # Enter whsec_your_webhook_secret
STRIPE_DEVICE_NAME= # Enter your Stripe device name
